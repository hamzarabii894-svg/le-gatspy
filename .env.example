# Copy these into Vercel → Project → Settings → Environment Variables.
# The site works WITHOUT them (WhatsApp fallback) — email needs both.

# API key from https://resend.com (free tier)
RESEND_API_KEY=

# Inbox that receives reservation requests
RESERVATION_EMAIL=

# Optional: verified sender address (default: onboarding@resend.dev)
# RESEND_FROM=Le Gatsby <reservations@legatsby.ma>
